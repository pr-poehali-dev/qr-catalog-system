{
  "tests": [
    {
      "name": "OPTIONS preflight",
      "method": "OPTIONS",
      "path": "/",
      "expectedStatus": 200
    },
    {
      "name": "GET not allowed",
      "method": "GET",
      "path": "/",
      "expectedStatus": 405
    },
    {
      "name": "POST without user",
      "method": "POST",
      "path": "/",
      "headers": {"Content-Type": "application/json"},
      "body": "{\"amount\": 10}",
      "expectedStatus": 401
    },
    {
      "name": "POST with low amount",
      "method": "POST",
      "path": "/",
      "headers": {"Content-Type": "application/json"},
      "body": "{\"amount\": 2, \"user_id\": \"test123\"}",
      "expectedStatus": 400
    }
  ]
}
